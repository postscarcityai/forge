    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "next": "15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite3": "^5.1.7",
    "tailwind-merge": "^3.3.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
