    "url": "https://github.com/postscarcityai/forge.git"
  },
  "private": false,
  "scripts": {
    "dev": "next dev -p 4900",
    "dev:with-mcp": "concurrently \"npm run dev\" \"npm run mcp:server\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:loras": "node scripts/seed-loras.js",
    "seed:sample": "node scripts/seed-sample-project.js",
    "mcp:server": "node scripts/start-mcp-server.js",
    "mcp:test": "node scripts/test-mcp-server.js",
    "mcp:connection": "node scripts/test-mcp-connection.js",
    "generate:images": "node scripts/brand-image-generator.js",
    "generate:images:interactive": "node scripts/brand-image-generator.js --interactive",
    "update-settings": "node scripts/update-project-settings.js",
    "download-images": "node scripts/download-project-images-simple.js",
    "download-images:dry-run": "node scripts/download-project-images-simple.js --dry-run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
