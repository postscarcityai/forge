{
  "name": "@postscarcityai/forge",
  "version": "1.0.0",
  "description": "Forge - A free and open-source AI image and video generation platform by PostScarcity AI. Create visual artifacts with access to all major generation models.",
  "keywords": [
    "ai",
    "image-generation",
    "video-generation",
    "creative-tools",
    "forge",
    "open-source",
    "nextjs",
    "postscarcity-ai",
    "fal-ai",
    "nano-banana",
    "veo"
  ],
