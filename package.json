    "@modelcontextprotocol/sdk": "^1.12.3",
    "@next/font": "^14.2.15",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
